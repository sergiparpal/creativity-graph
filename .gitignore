.venv/
.venv-*/
__pycache__/
*.pyc
.pytest_cache/
# Per-vault engine runtime artifacts — locks (incl. the `.stale` reclaim rename), reconcile state, the
# §1.8 grounding-audit log + its checkpoint sidecar, and the derived store. All disposable, never canon.
.kg-session-lock*
.kg-reconcile-state.json
.kg-ground-audit.jsonl*
.kg-data/
.tmp-*
*.Zone.Identifier
/derived/
uv.lock

# Optional LightRAG experiment-arm working store (index/vectors/cache): derived & disposable, never
# source of truth. Normally lives under .kg-data/derived/ (already ignored); pinned here explicitly so
# a relocated derived dir can't leak it into the canon.
**/derived/lightrag/

# Detached bootstrap worker log (runtime artifact)
provision.log
