{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/provision.mjs\"",
            "async": true,
            "timeout": 600,
            "statusMessage": "Provisioning the creativity-graph engine (one-time)…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/precontext.mjs\""
          }
        ]
      }
    ]
  }
}
